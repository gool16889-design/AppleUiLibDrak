            kbrow.Size = UDim2.new(0, 418, 0, 37)
            kbrow.Font = Enum.Font.Gotham
            kbrow.Text = name
            kbrow.TextColor3 = theme.textPrimary
            kbrow.TextSize = 21
            kbrow.TextWrapped = true
            kbrow.TextXAlignment = Enum.TextXAlignment.Left

            local kbbtn = Instance.new("TextButton")
            kbbtn.Parent = kbrow
            kbbtn.BackgroundColor3 = theme.elevated
            kbbtn.AnchorPoint = Vector2.new(1, 0.5)
            kbbtn.Position = UDim2.new(1, 0, 0.5, 0)
            kbbtn.Size = UDim2.new(0, 110, 0, 28)
            kbbtn.AutoButtonColor = false
            kbbtn.Font = Enum.Font.GothamMedium
            kbbtn.Text = currentKey and tostring(currentKey).gsub(tostring(currentKey), "Enum.KeyCode.", "") or "None"
            kbbtn.TextColor3 = theme.accent
            kbbtn.TextSize = 17
            kbbtn.ZIndex = 3

            local kbbtnUC = Instance.new("UICorner")
            kbbtnUC.CornerRadius = UDim.new(0, 7)
            kbbtnUC.Parent = kbbtn

            local kbbtnStroke = Instance.new("UIStroke")
            kbbtnStroke.Color = theme.border
            kbbtnStroke.Thickness = 1
            kbbtnStroke.Parent = kbbtn

            kbbtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                kbbtn.Text = "..."
                kbbtn.TextColor3 = theme.textMuted
                kbbtnStroke.Color = theme.accent

                local conn
                conn = UIS.InputBegan:Connect(function(input, gp)
                    if gp then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = input.KeyCode
                        local keyName = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
                        kbbtn.Text = keyName
                        kbbtn.TextColor3 = theme.accent
                        kbbtnStroke.Color = theme.border
                        listening = false
                        conn:Disconnect()
                        if callback then callback(currentKey) end
                    end
                end)
            end)

            -- trigger callback when key is pressed during gameplay
            UIS.InputBegan:Connect(function(input, gp)
                if gp then return end
                if not listening and input.KeyCode == currentKey then
                    if callback then callback(currentKey) end
                end
            end)
        end

        -- =====================================================
        -- COLORPICKER
        -- sec:ColorPicker(name, default, callback)
        -- default = Color3.fromRGB(255,0,0)
        -- callback получает Color3
        -- =====================================================
        function sec:ColorPicker(name, default, callback)
            local currentColor = default or Color3.fromRGB(255, 0, 0)
            local open = false
            local hue, sat, val = Color3.toHSV(currentColor)

            local cprow = Instance.new("Frame")
            cprow.Name = "cprow"
            cprow.Parent = workareamain
            cprow.BackgroundTransparency = 1
            cprow.Size = UDim2.new(0, 418, 0, 37)
            cprow.ClipsDescendants = false

            local cpLayout = Instance.new("UIListLayout")
            cpLayout.Parent = cprow
            cpLayout.SortOrder = Enum.SortOrder.LayoutOrder
            cpLayout.Padding = UDim.new(0, 6)

            -- header row
            local cpheader = Instance.new("Frame")
            cpheader.Parent = cprow
            cpheader.BackgroundTransparency = 1
            cpheader.Size = UDim2.new(0, 418, 0, 37)
            cpheader.LayoutOrder = 0

            local cplabel = Instance.new("TextLabel")
            cplabel.Parent = cpheader
            cplabel.BackgroundTransparency = 1
            cplabel.Size = UDim2.new(0.7, 0, 1, 0)
            cplabel.Font = Enum.Font.Gotham
            cplabel.Text = name
            cplabel.TextColor3 = theme.textPrimary
            cplabel.TextSize = 21
            cplabel.TextXAlignment = Enum.TextXAlignment.Left

            -- preview swatch + open button
            local cpbtn = Instance.new("TextButton")
            cpbtn.Parent = cpheader
            cpbtn.AnchorPoint = Vector2.new(1, 0.5)
            cpbtn.Position = UDim2.new(1, 0, 0.5, 0)
            cpbtn.Size = UDim2.new(0, 90, 0, 28)
            cpbtn.BackgroundColor3 = currentColor
            cpbtn.AutoButtonColor = false
            cpbtn.Font = Enum.Font.Gotham
            cpbtn.Text = ""
            cpbtn.ZIndex = 3

            local cpbtnUC = Instance.new("UICorner")
            cpbtnUC.CornerRadius = UDim.new(0, 7)
            cpbtnUC.Parent = cpbtn

            local cpbtnStroke = Instance.new("UIStroke")
            cpbtnStroke.Color = theme.border
            cpbtnStroke.Thickness = 1
            cpbtnStroke.Parent = cpbtn

            -- picker panel
            local panel = Instance.new("Frame")
            panel.Name = "cpanel"
            panel.Parent = cprow
            panel.BackgroundColor3 = theme.elevated
            panel.Size = UDim2.new(0, 418, 0, 150)
            panel.Visible = false
            panel.ZIndex = 5
            panel.LayoutOrder = 1
            panel.ClipsDescendants = true

            local panelUC = Instance.new("UICorner")
            panelUC.CornerRadius = UDim.new(0, 10)
            panelUC.Parent = panel

            local panelStroke = Instance.new("UIStroke")
            panelStroke.Color = theme.border
            panelStroke.Thickness = 1
            panelStroke.Parent = panel

            -- SV square (sat/val picker) — 130x130
            local svFrame = Instance.new("ImageLabel")
            svFrame.Parent = panel
            svFrame.Position = UDim2.new(0, 8, 0, 8)
            svFrame.Size = UDim2.new(0, 130, 0, 130)
            svFrame.ZIndex = 6
            -- White → Hue gradient
            svFrame.Image = "rbxassetid://6020299385" -- sat/val picker image
            svFrame.ImageColor3 = Color3.fromHSV(hue, 1, 1)

            local svUC = Instance.new("UICorner")
            svUC.CornerRadius = UDim.new(0, 6)
            svUC.Parent = svFrame

            -- SV cursor
            local svCursor = Instance.new("Frame")
            svCursor.Parent = svFrame
            svCursor.AnchorPoint = Vector2.new(0.5, 0.5)
            svCursor.Size = UDim2.new(0, 10, 0, 10)
            svCursor.Position = UDim2.new(sat, 0, 1 - val, 0)
            svCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
            svCursor.ZIndex = 8
            svCursor.BorderSizePixel = 0

            local svCursorUC = Instance.new("UICorner")
            svCursorUC.CornerRadius = UDim.new(1, 0)
            svCursorUC.Parent = svCursor

            local svCursorStroke = Instance.new("UIStroke")
            svCursorStroke.Color = Color3.fromRGB(0,0,0)
            svCursorStroke.Thickness = 1.5
            svCursorStroke.Parent = svCursor

            -- Hue bar — vertical, right of SV
            local hueBar = Instance.new("ImageLabel")
            hueBar.Parent = panel
            hueBar.Position = UDim2.new(0, 148, 0, 8)
            hueBar.Size = UDim2.new(0, 18, 0, 130)
            hueBar.ZIndex = 6
            hueBar.Image = "rbxassetid://6020299385" -- we'll override with gradient
            hueBar.Image = "" -- use UIGradient instead

            local hueBarUC = Instance.new("UICorner")
            hueBarUC.CornerRadius = UDim.new(0, 5)
            hueBarUC.Parent = hueBar

            -- rainbow gradient for hue bar
            local hueGrad = Instance.new("UIGradient")
            hueGrad.Parent = hueBar
            hueGrad.Rotation = 90
            hueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,   1, 1)),
                ColorSequenceKeypoint.new(0.167,Color3.fromHSV(0.167,1,1)),
                ColorSequenceKeypoint.new(0.333,Color3.fromHSV(0.333,1,1)),
                ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5, 1, 1)),
                ColorSequenceKeypoint.new(0.667,Color3.fromHSV(0.667,1,1)),
                ColorSequenceKeypoint.new(0.833,Color3.fromHSV(0.833,1,1)),
                ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,   1, 1)),
            })

            -- Hue cursor
            local hueCursor = Instance.new("Frame")
            hueCursor.Parent = hueBar
            hueCursor.AnchorPoint = Vector2.new(0.5, 0.5)
            hueCursor.Size = UDim2.new(1.4, 0, 0, 5)
            hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
            hueCursor.BackgroundColor3 = Color3.fromRGB(255,255,255)
            hueCursor.ZIndex = 8
            hueCursor.BorderSizePixel = 0

            local hueCursorUC = Instance.new("UICorner")
            hueCursorUC.CornerRadius = UDim.new(0, 3)
            hueCursorUC.Parent = hueCursor

            -- hex label + big preview
            local bigPreview = Instance.new("Frame")
            bigPreview.Parent = panel
            bigPreview.Position = UDim2.new(0, 178, 0, 8)
            bigPreview.Size = UDim2.new(0, 50, 0, 50)
            bigPreview.BackgroundColor3 = currentColor
            bigPreview.ZIndex = 6

            local bigPrevUC = Instance.new("UICorner")
            bigPrevUC.CornerRadius = UDim.new(0, 8)
            bigPrevUC.Parent = bigPreview

            local hexLabel = Instance.new("TextLabel")
            hexLabel.Parent = panel
            hexLabel.Position = UDim2.new(0, 178, 0, 66)
            hexLabel.Size = UDim2.new(0, 230, 0, 22)
            hexLabel.BackgroundTransparency = 1
            hexLabel.Font = Enum.Font.GothamMedium
            hexLabel.TextSize = 14
            hexLabel.TextColor3 = theme.textMuted
            hexLabel.TextXAlignment = Enum.TextXAlignment.Left
            hexLabel.ZIndex = 6

            local function colorToHex(c)
                return string.format("#%02X%02X%02X",
                    math.floor(c.R*255),
                    math.floor(c.G*255),
                    math.floor(c.B*255))
            end

            local function applyColor()
                currentColor = Color3.fromHSV(hue, sat, val)
                cpbtn.BackgroundColor3 = currentColor
                bigPreview.BackgroundColor3 = currentColor
                svFrame.ImageColor3 = Color3.fromHSV(hue, 1, 1)
                hexLabel.Text = colorToHex(currentColor)
                if callback then callback(currentColor) end
            end
            applyColor()

            -- SV drag
            local draggingSV = false
            local UIS = game:GetService("UserInputService")

            svFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = true
                    local rel = input.Position - svFrame.AbsolutePosition
                    sat = math.clamp(rel.X / svFrame.AbsoluteSize.X, 0, 1)
                    val = 1 - math.clamp(rel.Y / svFrame.AbsoluteSize.Y, 0, 1)
                    svCursor.Position = UDim2.new(sat, 0, 1 - val, 0)
                    applyColor()
                end
            end)

            -- Hue bar drag
            local draggingHue = false
            hueBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingHue = true
                    local relY = input.Position.Y - hueBar.AbsolutePosition.Y
                    hue = math.clamp(relY / hueBar.AbsoluteSize.Y, 0, 1)
                    hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
                    applyColor()
                end
            end)

            UIS.InputChanged:Connect(function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                if draggingSV then
                    local rel = input.Position - svFrame.AbsolutePosition
                    sat = math.clamp(rel.X / svFrame.AbsoluteSize.X, 0, 1)
                    val = 1 - math.clamp(rel.Y / svFrame.AbsoluteSize.Y, 0, 1)
                    svCursor.Position = UDim2.new(sat, 0, 1 - val, 0)
                    applyColor()
                elseif draggingHue then
                    local relY = input.Position.Y - hueBar.AbsolutePosition.Y
                    hue = math.clamp(relY / hueBar.AbsoluteSize.Y, 0, 1)
                    hueCursor.Position = UDim2.new(0.5, 0, hue, 0)
                    applyColor()
                end
            end)

            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = false
                    draggingHue = false
                end
            end)

            -- toggle open
            cpbtn.MouseButton1Click:Connect(function()
                open = not open
                panel.Visible = open
                if open then
                    cprow.Size = UDim2.new(0, 418, 0, 37 + 6 + 150)
                    cpbtnStroke.Color = theme.accent
                else
                    cprow.Size = UDim2.new(0, 418, 0, 37)
                    cpbtnStroke.Color = theme.border
                end
            end)
        end

        sidebar2.MouseButton1Click:Connect(function()
            sec:Select()
        end)

        return sec
    end

    return window
end

return lib
