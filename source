        -- SLIDER
        -- sec:Slider(name, min, max, default, callback)
        -- =====================================================
        function sec:Slider(name, min, max, default, callback)
            local value = math.clamp(default or min, min, max)
            local UIS = game:GetService("UserInputService")
            local draggingSlider = false

            -- row container (fixed height 50px: 22 label + 10 track + padding)
            local row = Instance.new("Frame")
            row.Name = "sliderrow"
            row.Parent = workareamain
            row.BackgroundTransparency = 1
            row.Size = UDim2.new(0, 418, 0, 50)

            -- name label
            local namelbl = Instance.new("TextLabel")
            namelbl.Parent = row
            namelbl.BackgroundTransparency = 1
            namelbl.Position = UDim2.new(0, 0, 0, 0)
            namelbl.Size = UDim2.new(0.72, 0, 0, 22)
            namelbl.Font = Enum.Font.Gotham
            namelbl.Text = name
            namelbl.TextColor3 = theme.textPrimary
            namelbl.TextSize = 19
            namelbl.TextXAlignment = Enum.TextXAlignment.Left

            -- value label (right)
            local vallbl = Instance.new("TextLabel")
            vallbl.Parent = row
            vallbl.BackgroundTransparency = 1
            vallbl.Position = UDim2.new(0.72, 0, 0, 0)
            vallbl.Size = UDim2.new(0.28, 0, 0, 22)
            vallbl.Font = Enum.Font.GothamMedium
            vallbl.Text = tostring(value)
            vallbl.TextColor3 = theme.accent
            vallbl.TextSize = 18
            vallbl.TextXAlignment = Enum.TextXAlignment.Right

            -- track background
            local track = Instance.new("Frame")
            track.Parent = row
            track.BackgroundColor3 = theme.elevated
            track.Position = UDim2.new(0, 0, 0, 30)
            track.Size = UDim2.new(1, 0, 0, 10)
            track.BorderSizePixel = 0

            local trackUC = Instance.new("UICorner")
            trackUC.CornerRadius = UDim.new(1, 0)
            trackUC.Parent = track

            local trackStroke = Instance.new("UIStroke")
            trackStroke.Color = theme.border
            trackStroke.Thickness = 1
            trackStroke.Parent = track

            -- fill
            local fill = Instance.new("Frame")
            fill.Parent = track
            fill.BackgroundColor3 = theme.accent
            fill.BorderSizePixel = 0
            fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)

            local fillUC = Instance.new("UICorner")
            fillUC.CornerRadius = UDim.new(1, 0)
            fillUC.Parent = fill

            -- thumb
            local thumb = Instance.new("Frame")
            thumb.Parent = track
            thumb.BackgroundColor3 = Color3.fromRGB(230, 230, 240)
            thumb.AnchorPoint = Vector2.new(0.5, 0.5)
            thumb.Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0)
            thumb.Size = UDim2.new(0, 14, 0, 14)
            thumb.ZIndex = 2
            thumb.BorderSizePixel = 0

            local thumbUC = Instance.new("UICorner")
            thumbUC.CornerRadius = UDim.new(1, 0)
            thumbUC.Parent = thumb

            local function setSlider(inputX)
                local ap = track.AbsolutePosition.X
                local as = track.AbsoluteSize.X
                local rel = math.clamp((inputX - ap) / as, 0, 1)
                value = math.floor(min + (max - min) * rel)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                thumb.Position = UDim2.new(rel, 0, 0.5, 0)
                vallbl.Text = tostring(value)
                if callback then callback(value) end
            end

            track.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                    setSlider(inp.Position.X)
                end
            end)
            thumb.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                end
            end)
            UIS.InputChanged:Connect(function(inp)
                if draggingSlider and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    setSlider(inp.Position.X)
                end
            end)
            UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)
        end

        -- =====================================================
        -- DROPDOWN
        -- sec:Dropdown(name, options, default, callback)
        -- =====================================================
        function sec:Dropdown(name, options, default, callback)
            local selected = default or options[1]
            local open = false
            local ITEM_H = 30
            local LIST_PAD = 8
            local listHeight = #options * ITEM_H + LIST_PAD

            -- outer wrapper: ClipsDescendants = false so list overflows
            local wrapper = Instance.new("Frame")
            wrapper.Name = "ddwrapper"
            wrapper.Parent = workareamain
            wrapper.BackgroundTransparency = 1
            wrapper.ClipsDescendants = false
            wrapper.Size = UDim2.new(0, 418, 0, 37)

            -- header row (always visible)
            local header = Instance.new("Frame")
            header.Parent = wrapper
            header.BackgroundTransparency = 1
            header.Size = UDim2.new(0, 418, 0, 37)

            local namelbl = Instance.new("TextLabel")
            namelbl.Parent = header
            namelbl.BackgroundTransparency = 1
            namelbl.Size = UDim2.new(0, 184, 0, 37)  -- fixed ~44% of 418
            namelbl.Font = Enum.Font.Gotham
            namelbl.Text = name
            namelbl.TextColor3 = theme.textPrimary
            namelbl.TextSize = 19
            namelbl.TextXAlignment = Enum.TextXAlignment.Left

            -- the button that shows current selection
            local btn = Instance.new("TextButton")
            btn.Parent = header
            btn.BackgroundColor3 = theme.elevated
            btn.Position = UDim2.new(0, 188, 0, 1)   -- right of label
            btn.Size = UDim2.new(0, 230, 0, 35)
            btn.AutoButtonColor = false
            btn.Font = Enum.Font.Gotham
            btn.Text = selected .. "  ▾"
            btn.TextColor3 = theme.textPrimary
            btn.TextSize = 17
            btn.ZIndex = 4

            local btnUC = Instance.new("UICorner")
            btnUC.CornerRadius = UDim.new(0, 9)
            btnUC.Parent = btn

            local btnStroke = Instance.new("UIStroke")
            btnStroke.Color = theme.border
            btnStroke.Thickness = 1
            btnStroke.Parent = btn

            -- dropdown list: positioned ABSOLUTE below the button
            -- parented to wrapper (not to workareamain) so it overlays items below
            local ddlist = Instance.new("Frame")
            ddlist.Name = "ddlist"
            ddlist.Parent = wrapper
            ddlist.BackgroundColor3 = theme.elevated
            ddlist.Position = UDim2.new(0, 188, 0, 41)  -- same X as btn, just below
            ddlist.Size = UDim2.new(0, 230, 0, listHeight)
            ddlist.Visible = false
            ddlist.ZIndex = 20
            ddlist.ClipsDescendants = true
            ddlist.BorderSizePixel = 0

            local ddlistUC = Instance.new("UICorner")
            ddlistUC.CornerRadius = UDim.new(0, 9)
            ddlistUC.Parent = ddlist

            local ddlistStroke = Instance.new("UIStroke")
            ddlistStroke.Color = theme.accent
            ddlistStroke.Thickness = 1
            ddlistStroke.Parent = ddlist

            local ddlistLayout = Instance.new("UIListLayout")
            ddlistLayout.Parent = ddlist
            ddlistLayout.SortOrder = Enum.SortOrder.LayoutOrder
            ddlistLayout.Padding = UDim.new(0, 0)

            local ddlistPad = Instance.new("UIPadding")
            ddlistPad.Parent = ddlist
            ddlistPad.PaddingTop = UDim.new(0, 4)
            ddlistPad.PaddingBottom = UDim.new(0, 4)
            ddlistPad.PaddingLeft = UDim.new(0, 5)
            ddlistPad.PaddingRight = UDim.new(0, 5)

            local optButtons = {}
            for i, opt in ipairs(options) do
                local optbtn = Instance.new("TextButton")
                optbtn.Parent = ddlist
                optbtn.BackgroundColor3 = theme.border
                optbtn.BackgroundTransparency = 1
                optbtn.Size = UDim2.new(1, 0, 0, ITEM_H)
                optbtn.Font = Enum.Font.Gotham
                optbtn.Text = opt
                optbtn.TextColor3 = (opt == selected) and theme.accent or theme.textPrimary
                optbtn.TextSize = 16
                optbtn.ZIndex = 21
                optbtn.AutoButtonColor = false
                optbtn.LayoutOrder = i

                local optUC = Instance.new("UICorner")
                optUC.CornerRadius = UDim.new(0, 6)
                optUC.Parent = optbtn

                table.insert(optButtons, optbtn)

                optbtn.MouseEnter:Connect(function()
                    if opt ~= selected then
                        optbtn.BackgroundTransparency = 0
                    end
                end)
                optbtn.MouseLeave:Connect(function()
                    if opt ~= selected then
                        optbtn.BackgroundTransparency = 1
                    end
                end)
                optbtn.MouseButton1Click:Connect(function()
                    selected = opt
                    btn.Text = selected .. "  ▾"
                    btnStroke.Color = theme.border
                    -- reset colours
                    for _, ob in ipairs(optButtons) do
                        ob.TextColor3 = theme.textPrimary
                        ob.BackgroundTransparency = 1
                    end
                    optbtn.TextColor3 = theme.accent
                    optbtn.BackgroundTransparency = 0
                    open = false
                    ddlist.Visible = false
                    if callback then callback(selected) end
                end)
            end

            btn.MouseButton1Click:Connect(function()
                open = not open
                ddlist.Visible = open
                if open then
                    btn.Text = selected .. "  ▴"
                    btnStroke.Color = theme.accent
                else
                    btn.Text = selected .. "  ▾"
                    btnStroke.Color = theme.border
                end
            end)
        end

        -- =====================================================
        -- KEYBIND
        -- sec:Keybind(name, default, callback)
        -- callback вызывается при назначении и при нажатии
        -- =====================================================
        function sec:Keybind(name, default, callback)
            local currentKey = default
            local listening = false
            local UIS = game:GetService("UserInputService")

            local row = Instance.new("Frame")
            row.Name = "kbrow"
            row.Parent = workareamain
            row.BackgroundTransparency = 1
            row.Size = UDim2.new(0, 418, 0, 37)

            local namelbl = Instance.new("TextLabel")
            namelbl.Parent = row
            namelbl.BackgroundTransparency = 1
            namelbl.Size = UDim2.new(0, 290, 0, 37)
            namelbl.Font = Enum.Font.Gotham
            namelbl.Text = name
            namelbl.TextColor3 = theme.textPrimary
            namelbl.TextSize = 19
            namelbl.TextXAlignment = Enum.TextXAlignment.Left

            local function keyName(kc)
                if not kc then return "None" end
                return tostring(kc):gsub("Enum.KeyCode.", "")
            end

            local kbbtn = Instance.new("TextButton")
            kbbtn.Parent = row
            kbbtn.BackgroundColor3 = theme.elevated
            kbbtn.Position = UDim2.new(0, 294, 0, 4)
            kbbtn.Size = UDim2.new(0, 120, 0, 29)
            kbbtn.AutoButtonColor = false
            kbbtn.Font = Enum.Font.GothamMedium
            kbbtn.Text = keyName(currentKey)
            kbbtn.TextColor3 = theme.accent
            kbbtn.TextSize = 16
            kbbtn.ZIndex = 3

            local kbUC = Instance.new("UICorner")
            kbUC.CornerRadius = UDim.new(0, 7)
            kbUC.Parent = kbbtn

            local kbStroke = Instance.new("UIStroke")
            kbStroke.Color = theme.border
            kbStroke.Thickness = 1
            kbStroke.Parent = kbbtn

            kbbtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                kbbtn.Text = "..."
                kbbtn.TextColor3 = theme.textMuted
                kbStroke.Color = theme.accent

                local conn
                conn = UIS.InputBegan:Connect(function(inp, gp)
                    if gp then return end
                    if inp.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = inp.KeyCode
                        kbbtn.Text = keyName(currentKey)
                        kbbtn.TextColor3 = theme.accent
                        kbStroke.Color = theme.border
                        listening = false
                        conn:Disconnect()
                        if callback then callback(currentKey) end
                    end
                end)
            end)

            -- fire callback when assigned key is pressed during gameplay
            UIS.InputBegan:Connect(function(inp, gp)
                if gp then return end
                if not listening and currentKey and inp.KeyCode == currentKey then
                    if callback then callback(currentKey) end
                end
            end)
        end

        -- =====================================================
        -- COLORPICKER
        -- sec:ColorPicker(name, default, callback)
        -- =====================================================
        function sec:ColorPicker(name, default, callback)
            local currentColor = default or Color3.fromRGB(255, 0, 0)
            local open = false
            local UIS = game:GetService("UserInputService")
            local h, s, v = Color3.toHSV(currentColor)

            local PANEL_H = 158

            -- row wrapper
            local cprow = Instance.new("Frame")
            cprow.Name = "cprow"
            cprow.Parent = workareamain
            cprow.BackgroundTransparency = 1
            cprow.ClipsDescendants = false
            cprow.Size = UDim2.new(0, 418, 0, 37)

            -- header
            local namelbl = Instance.new("TextLabel")
            namelbl.Parent = cprow
            namelbl.BackgroundTransparency = 1
            namelbl.Size = UDim2.new(0, 290, 0, 37)
            namelbl.Font = Enum.Font.Gotham
            namelbl.Text = name
            namelbl.TextColor3 = theme.textPrimary
            namelbl.TextSize = 19
            namelbl.TextXAlignment = Enum.TextXAlignment.Left

            -- swatch preview button
            local swatchBtn = Instance.new("TextButton")
            swatchBtn.Parent = cprow
            swatchBtn.Position = UDim2.new(0, 294, 0, 4)
            swatchBtn.Size = UDim2.new(0, 120, 0, 29)
            swatchBtn.BackgroundColor3 = currentColor
            swatchBtn.AutoButtonColor = false
            swatchBtn.Text = ""
            swatchBtn.ZIndex = 3

            local swatchUC = Instance.new("UICorner")
            swatchUC.CornerRadius = UDim.new(0, 7)
            swatchUC.Parent = swatchBtn

            local swatchStroke = Instance.new("UIStroke")
            swatchStroke.Color = theme.border
            swatchStroke.Thickness = 1
            swatchStroke.Parent = swatchBtn

            -- panel (opens below the row)
            local panel = Instance.new("Frame")
            panel.Name = "cpanel"
            panel.Parent = cprow
            panel.BackgroundColor3 = theme.elevated
            panel.Position = UDim2.new(0, 0, 0, 41)
            panel.Size = UDim2.new(0, 418, 0, PANEL_H)
            panel.Visible = false
            panel.ZIndex = 15
            panel.BorderSizePixel = 0
            panel.ClipsDescendants = false

            local panelUC = Instance.new("UICorner")
            panelUC.CornerRadius = UDim.new(0, 10)
            panelUC.Parent = panel

            local panelStroke = Instance.new("UIStroke")
            panelStroke.Color = theme.border
            panelStroke.Thickness = 1
            panelStroke.Parent = panel

            -- SV square (sat horizontal, val vertical inverted)
            local SV_SIZE = 130
            local svFrame = Instance.new("Frame")
            svFrame.Parent = panel
            svFrame.Position = UDim2.new(0, 10, 0, 10)
            svFrame.Size = UDim2.new(0, SV_SIZE, 0, SV_SIZE)
            svFrame.ZIndex = 16
            svFrame.BorderSizePixel = 0
            svFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)

            local svUC = Instance.new("UICorner")
            svUC.CornerRadius = UDim.new(0, 6)
            svUC.Parent = svFrame

            -- white → transparent gradient (left=white, right=hue)
            local svGradH = Instance.new("UIGradient")
            svGradH.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255)),
            })
            svGradH.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, 0),
            })
            svGradH.Rotation = 0  -- left=white(opaque), right=transparent so hue shows
            svGradH.Parent = svFrame

            -- black overlay (bottom=black)
            local svDark = Instance.new("Frame")
            svDark.Parent = svFrame
            svDark.Size = UDim2.new(1,0,1,0)
            svDark.BackgroundColor3 = Color3.fromRGB(0,0,0)
            svDark.ZIndex = 17
            svDark.BorderSizePixel = 0

            local svDarkUC = Instance.new("UICorner")
            svDarkUC.CornerRadius = UDim.new(0, 6)
            svDarkUC.Parent = svDark

            local svDarkGrad = Instance.new("UIGradient")
            svDarkGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0)),
            })
            svDarkGrad.Transparency = NumberSequence.new({
                NumberSequenceKeypoint.new(0, 1),
                NumberSequenceKeypoint.new(1, 0),
            })
            svDarkGrad.Rotation = 90  -- top=transparent, bottom=black
            svDarkGrad.Parent = svDark

            -- SV cursor
            local svCursor = Instance.new("Frame")
            svCursor.Parent = svDark
            svCursor.AnchorPoint = Vector2.new(0.5, 0.5)
            svCursor.Size = UDim2.new(0, 10, 0, 10)
            svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
            svCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            svCursor.ZIndex = 19
            svCursor.BorderSizePixel = 0

            local svCursorUC = Instance.new("UICorner")
            svCursorUC.CornerRadius = UDim.new(1, 0)
            svCursorUC.Parent = svCursor

            local svCursorStroke = Instance.new("UIStroke")
            svCursorStroke.Color = Color3.fromRGB(0, 0, 0)
            svCursorStroke.Thickness = 1.5
            svCursorStroke.Parent = svCursor

            -- Hue bar (vertical rainbow)
            local hueBar = Instance.new("Frame")
            hueBar.Parent = panel
            hueBar.Position = UDim2.new(0, 150, 0, 10)
            hueBar.Size = UDim2.new(0, 16, 0, SV_SIZE)
            hueBar.ZIndex = 16
            hueBar.BorderSizePixel = 0
            hueBar.BackgroundColor3 = Color3.fromRGB(255, 255, 255)

            local hueBarUC = Instance.new("UICorner")
            hueBarUC.CornerRadius = UDim.new(0, 5)
            hueBarUC.Parent = hueBar

            local hueGrad = Instance.new("UIGradient")
            hueGrad.Rotation = 90
            hueGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0,     Color3.fromHSV(0,     1, 1)),
                ColorSequenceKeypoint.new(1/6,   Color3.fromHSV(1/6,   1, 1)),
                ColorSequenceKeypoint.new(2/6,   Color3.fromHSV(2/6,   1, 1)),
                ColorSequenceKeypoint.new(3/6,   Color3.fromHSV(3/6,   1, 1)),
                ColorSequenceKeypoint.new(4/6,   Color3.fromHSV(4/6,   1, 1)),
                ColorSequenceKeypoint.new(5/6,   Color3.fromHSV(5/6,   1, 1)),
                ColorSequenceKeypoint.new(1,     Color3.fromHSV(0,     1, 1)),
            })
            hueGrad.Parent = hueBar

            -- Hue cursor
            local hueCursor = Instance.new("Frame")
            hueCursor.Parent = hueBar
            hueCursor.AnchorPoint = Vector2.new(0.5, 0.5)
            hueCursor.Size = UDim2.new(1.5, 0, 0, 5)
            hueCursor.Position = UDim2.new(0.5, 0, h, 0)
            hueCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            hueCursor.ZIndex = 18
            hueCursor.BorderSizePixel = 0

            local hueCursorUC = Instance.new("UICorner")
            hueCursorUC.CornerRadius = UDim.new(0, 3)
            hueCursorUC.Parent = hueCursor

            local hueCursorStroke = Instance.new("UIStroke")
            hueCursorStroke.Color = Color3.fromRGB(0,0,0)
            hueCursorStroke.Thickness = 1
            hueCursorStroke.Parent = hueCursor

            -- big preview swatch inside panel
            local bigPrev = Instance.new("Frame")
            bigPrev.Parent = panel
            bigPrev.Position = UDim2.new(0, 178, 0, 10)
            bigPrev.Size = UDim2.new(0, 55, 0, 55)
            bigPrev.BackgroundColor3 = currentColor
            bigPrev.ZIndex = 16
            bigPrev.BorderSizePixel = 0

            local bigPrevUC = Instance.new("UICorner")
            bigPrevUC.CornerRadius = UDim.new(0, 8)
            bigPrevUC.Parent = bigPrev

            -- hex label
            local hexLbl = Instance.new("TextLabel")
            hexLbl.Parent = panel
            hexLbl.BackgroundTransparency = 1
            hexLbl.Position = UDim2.new(0, 178, 0, 72)
            hexLbl.Size = UDim2.new(0, 230, 0, 20)
            hexLbl.Font = Enum.Font.GothamMedium
            hexLbl.TextSize = 14
            hexLbl.TextColor3 = theme.textMuted
            hexLbl.TextXAlignment = Enum.TextXAlignment.Left
            hexLbl.ZIndex = 16

            -- RGB labels
            local rgbLbl = Instance.new("TextLabel")
            rgbLbl.Parent = panel
            rgbLbl.BackgroundTransparency = 1
            rgbLbl.Position = UDim2.new(0, 178, 0, 94)
            rgbLbl.Size = UDim2.new(0, 230, 0, 20)
            rgbLbl.Font = Enum.Font.Gotham
            rgbLbl.TextSize = 13
            rgbLbl.TextColor3 = theme.textMuted
            rgbLbl.TextXAlignment = Enum.TextXAlignment.Left
            rgbLbl.ZIndex = 16

            local function applyColor()
                currentColor = Color3.fromHSV(h, s, v)
                svFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                hueCursor.Position = UDim2.new(0.5, 0, h, 0)
                swatchBtn.BackgroundColor3 = currentColor
                bigPrev.BackgroundColor3 = currentColor
                hexLbl.Text = string.format("#%02X%02X%02X",
                    math.floor(currentColor.R * 255),
                    math.floor(currentColor.G * 255),
                    math.floor(currentColor.B * 255))
                rgbLbl.Text = string.format("R %d  G %d  B %d",
                    math.floor(currentColor.R * 255),
                    math.floor(currentColor.G * 255),
                    math.floor(currentColor.B * 255))
                if callback then callback(currentColor) end
            end
            applyColor()

            -- drag state
            local draggingSV = false
            local draggingHue = false

            svDark.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = true
                    local rel = inp.Position - svFrame.AbsolutePosition
                    s = math.clamp(rel.X / svFrame.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp(rel.Y / svFrame.AbsoluteSize.Y, 0, 1)
                    applyColor()
                end
            end)
            svFrame.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = true
                end
            end)

            hueBar.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingHue = true
                    h = math.clamp((inp.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                    applyColor()
                end
            end)

            UIS.InputChanged:Connect(function(inp)
                if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                if draggingSV then
                    local rel = inp.Position - svFrame.AbsolutePosition
                    s = math.clamp(rel.X / svFrame.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp(rel.Y / svFrame.AbsoluteSize.Y, 0, 1)
                    applyColor()
                elseif draggingHue then
                    h = math.clamp((inp.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                    applyColor()
                end
            end)

            UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = false
                    draggingHue = false
                end
            end)

            swatchBtn.MouseButton1Click:Connect(function()
                open = not open
                panel.Visible = open
                if open then
                    swatchStroke.Color = theme.accent
                    cprow.Size = UDim2.new(0, 418, 0, 37 + 6 + PANEL_H)
                else
                    swatchStroke.Color = theme.border
                    cprow.Size = UDim2.new(0, 418, 0, 37)
                end
            end)
        end

        sidebar2.MouseButton1Click:Connect(function()
            sec:Select()
        end)

        return sec
    end

    return window
end

return lib
