        -- SLIDER
        -- sec:Slider(name, min, max, default, callback)
        -- callback получает number
        -- =====================================================
        function sec:Slider(name, min, max, default, callback)
            local value = math.clamp(default or min, min, max)

            local sliderrow = Instance.new("TextLabel")
            sliderrow.Name = "sliderrow"
            sliderrow.Parent = workareamain
            sliderrow.BackgroundTransparency = 1
            sliderrow.Size = UDim2.new(0, 418, 0, 46)
            sliderrow.Font = Enum.Font.Gotham
            sliderrow.Text = name
            sliderrow.TextColor3 = theme.textPrimary
            sliderrow.TextSize = 21
            sliderrow.TextWrapped = true
            sliderrow.TextXAlignment = Enum.TextXAlignment.Left

            -- value label
            local vallabel = Instance.new("TextLabel")
            vallabel.Parent = sliderrow
            vallabel.BackgroundTransparency = 1
            vallabel.AnchorPoint = Vector2.new(1, 0)
            vallabel.Position = UDim2.new(1, 0, 0, 0)
            vallabel.Size = UDim2.new(0, 60, 0, 22)
            vallabel.Font = Enum.Font.GothamMedium
            vallabel.Text = tostring(value)
            vallabel.TextColor3 = theme.accent
            vallabel.TextSize = 18
            vallabel.TextXAlignment = Enum.TextXAlignment.Right

            -- track bg
            local track = Instance.new("Frame")
            track.Parent = sliderrow
            track.BackgroundColor3 = theme.elevated
            track.Position = UDim2.new(0, 0, 0, 28)
            track.Size = UDim2.new(1, 0, 0, 10)

            local trackStroke = Instance.new("UIStroke")
            trackStroke.Color = theme.border
            trackStroke.Thickness = 1
            trackStroke.Parent = track

            local uc_sl1 = Instance.new("UICorner")
            uc_sl1.CornerRadius = UDim.new(1, 0)
            uc_sl1.Parent = track

            -- fill
            local fill = Instance.new("Frame")
            fill.Parent = track
            fill.BackgroundColor3 = theme.accent
            fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
            fill.BorderSizePixel = 0

            local uc_sl2 = Instance.new("UICorner")
            uc_sl2.CornerRadius = UDim.new(1, 0)
            uc_sl2.Parent = fill

            -- thumb
            local thumb = Instance.new("Frame")
            thumb.Parent = track
            thumb.BackgroundColor3 = Color3.fromRGB(230, 230, 240)
            thumb.AnchorPoint = Vector2.new(0.5, 0.5)
            thumb.Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0)
            thumb.Size = UDim2.new(0, 16, 0, 16)
            thumb.ZIndex = 2

            local uc_sl3 = Instance.new("UICorner")
            uc_sl3.CornerRadius = UDim.new(1, 0)
            uc_sl3.Parent = thumb

            -- drag logic
            local draggingSlider = false
            local UIS = game:GetService("UserInputService")

            local function updateSlider(inputX)
                local absPos = track.AbsolutePosition.X
                local absSize = track.AbsoluteSize.X
                local rel = math.clamp((inputX - absPos) / absSize, 0, 1)
                value = math.floor(min + (max - min) * rel)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                thumb.Position = UDim2.new(rel, 0, 0.5, 0)
                vallabel.Text = tostring(value)
                if callback then callback(value) end
            end

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                    updateSlider(input.Position.X)
                end
            end)
            thumb.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                end
            end)
            UIS.InputChanged:Connect(function(input)
                if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input.Position.X)
                end
            end)
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = false
                end
            end)
        end

